# DB_PORT=5432
# DB_NAME=tontine
# DB_USER=postgres
# DB_PASSWORD=yourpassword

# Optional: JWT Configuration
# JWT_SECRET=your-secret-key
# JWT_EXPIRY=7d

# Optional: Firebase Configuration
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_MESSAGING_SENDER_ID=
