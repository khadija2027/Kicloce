# Backend Environment Variables
NODE_ENV=production
PORT=7860

# API Configuration
API_BASE_URL=http://localhost:7860
API_TIMEOUT=30000

# Frontend Configuration (if needed)
VITE_API_BASE_URL=http://localhost:7860

# Optional: Database Configuration (for future use)
